# Copy to .env and fill in. Do not commit .env (it is in .gitignore).

# --- Voice (TTS) — áp dụng cho tất cả video khi chạy generate-tts.py ---
# Edge-TTS (mặc định, miễn phí). Danh sách: https://speech.microsoft.com/portal/voicegallery
# EDGE_VOICE=vi-VN-NamMinhNeural
# Hoặc giọng nữ: vi-VN-HoaiMyNeural, vi-VN-ThanhMaiNeural

# ElevenLabs (tùy chọn). Get key at https://elevenlabs.io
# TTS_ENGINE=elevenlabs
# ELEVENLABS_API_KEY=sk_...
# Voice: phát âm tốt tiếng Việt + thuật ngữ tiếng Anh. Mặc định: Adam (multilingual).
# Đổi voice: lấy Voice ID tại https://elevenlabs.io/voice-library, gán vào đây.
# ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# Google Cloud TTS (tùy chọn). Get key at https://console.cloud.google.com/apis/credentials
# TTS_ENGINE=google
# GOOGLE_TTS_API_KEY=AIza...
# Voices: vi-VN-Neural2-A (Female), vi-VN-Neural2-D (Male), vi-VN-Wavenet-A/B/C/D
# GOOGLE_TTS_VOICE=vi-VN-Neural2-D

# Sau khi đổi voice, tạo lại TTS cho tất cả video: npm run tts:all

# --- Image Assets (minh họa 2D cho video) ---
# Pixabay (ưu tiên — illustrations + photos). Get free key: https://pixabay.com/api/docs/#api_key
PIXABAY_API_KEY=

# Pexels (fallback — photos). Get free key: https://www.pexels.com/api/
# PEXELS_API_KEY=
